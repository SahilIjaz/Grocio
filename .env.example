# ==========================================
# GROCIO BACKEND - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file and update with your actual values
# NEVER commit real secrets to the repository

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

# ==========================================
# DATABASE (Render PostgreSQL or Neon)
# ==========================================
# For Render PostgreSQL service:
DATABASE_URL=postgresql://user:password@dpg-xxxxx.render.internal:5432/grocio_db?sslmode=require

# Legacy Neon configuration (optional):
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your_password_here

# ==========================================
# REDIS (Render Redis or Redis Labs)
# ==========================================
# For Render Redis service:
REDIS_URL=redis://:password@dpg-xxxxx.render.internal:6379

# For Redis Labs / RedisCloud:
# REDIS_HOST=redis-xxxxx.c301.ap-south-1-1.ec2.cloud.redislabs.com
# REDIS_PORT=18148
# REDIS_PASSWORD=your_password_here
# REDIS_URL=redis://:password@host:port

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_PRIVATE_KEY=your_rsa_private_key_here
JWT_PUBLIC_KEY=your_rsa_public_key_here

# ==========================================
# CORS CONFIGURATION
# ==========================================
# For production with Vercel frontend:
CORS_ORIGINS=https://your-frontend.vercel.app,https://www.your-domain.com

# ==========================================
# API CONFIGURATION
# ==========================================
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# ==========================================
# CLOUDINARY (Image Upload Service)
# ==========================================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# EMAIL CONFIGURATION (Gmail)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_not_regular_password
SMTP_FROM=noreply@grocio.com

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
# Options: error, warn, info, debug, trace

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# SECURITY
# ==========================================
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_key_change_this

# ==========================================
# OPTIONAL: Sentry Error Tracking
# ==========================================
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ==========================================
# OPTIONAL: Analytics
# ==========================================
ANALYTICS_API_KEY=your_analytics_key
