# Test Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://grocio_test_user:grocio_test_password@localhost:5432/grocio_test

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=test_password

# JWT Configuration (test keys)
JWT_PRIVATE_KEY=test_private_key
JWT_PUBLIC_KEY=test_public_key

# Application Configuration
NODE_ENV=test
API_PREFIX=/api/v1
PORT=3000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cloudinary Configuration (test account)
CLOUDINARY_NAME=test_cloudinary
CLOUDINARY_API_KEY=test_api_key
CLOUDINARY_API_SECRET=test_api_secret

# Monitoring Configuration
SENTRY_DSN=
LOG_LEVEL=debug

# Email Configuration (disabled in tests)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=test@example.com
