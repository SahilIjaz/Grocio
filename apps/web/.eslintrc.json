{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "@typescript-eslint/explicit-function-return-types": "off",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "@next/next/no-img-element": "off",
    "react/no-unescaped-entities": "off"
  }
}
