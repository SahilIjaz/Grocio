{
  "name": "@grocio/api",
  "version": "0.1.0",
  "description": "Grocio Multi-Tenant API",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "api",
    "nodejs",
    "express",
    "typescript",
    "postgresql",
    "prisma",
    "multi-tenant"
  ],
  "author": "Engineering Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.16.0",
    "axios": "catalog:",
    "bcrypt": "catalog:",
    "cloudinary": "catalog:",
    "cors": "catalog:",
    "dotenv": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "helmet": "catalog:",
    "ioredis": "catalog:",
    "jsonwebtoken": "catalog:",
    "morgan": "catalog:",
    "multer": "catalog:",
    "prisma": "catalog:",
    "rate-limit-redis": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "catalog:",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "catalog:",
    "supertest": "catalog:",
    "tsx": "^4.7.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
